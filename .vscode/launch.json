{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Current Rust Example",
      "type": "lldb",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "cargo": {
        "args": [
          "build",
          "--example",
          "${fileBasenameNoExtension}"
        ],
        "filter": {
          "kind": "example",
          "name": "${fileBasenameNoExtension}"
        }
      },
      "args": []
    }
  ]
}
